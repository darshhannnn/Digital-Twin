# ─────────────────────────────────────────────────────────────────
#  Digital Twin — Environment Variables
#  Copy this file to .env and fill in your real values.
#  .env is gitignored — never commit your actual keys!
# ─────────────────────────────────────────────────────────────────

# Telegram bot (create via @BotFather, then message your bot and get chat_id)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord webhook (optional — Settings > Integrations > Webhooks in your server)
DISCORD_WEBHOOK_URL=

# Ollama local server (default is fine if running locally)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Personal info for job application form filling
FULL_NAME=Your Full Name
EMAIL=your.email@example.com

# Dashboard (default: localhost:5000 only)
DASHBOARD_PORT=5000
DASHBOARD_HOST=127.0.0.1
